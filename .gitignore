# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ipynb_checkpoints/

# Environments
venv/
.venv/
env/
.env
.env.local

# Data — never commit large/raw data (use DVC pointers instead)
data/*
!data/.gitkeep
# ...except the small frozen FRED vintage snapshots (reproducibility)
!data/fred_nk_*.csv

# Results: keep the directory, ignore generated artifacts by default
results/*
!results/.gitkeep
# ...except the canonical figures referenced by the README (regenerable)
!results/rbc_irf.png
!results/nk_irf.png
!results/size_gate.png

# OS
.DS_Store
